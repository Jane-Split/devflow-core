{
  "$schema": "https://docs.trae.ai/schemas/skills.json",
  "version": "1.0.0",
  "name": "DevFlow",
  "description": "AI 驱动的开发工作流编排工具",
  "author": "DevFlow Team",
  "skills": [
    {
      "id": "devflow-init",
      "name": "初始化项目",
      "command": "/devflow-init",
      "description": "初始化 DevFlow 配置，分析项目结构",
      "icon": "$(folder-opened)",
      "category": "项目设置",
      "input": {
        "type": "arguments",
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "项目名称"
            },
            "type": {
              "type": "string",
              "enum": ["frontend", "backend", "fullstack", "microservice"],
              "description": "项目类型"
            },
            "force": {
              "type": "boolean",
              "description": "强制重新初始化"
            }
          }
        }
      },
      "handler": {
        "type": "cli",
        "command": "node ${workspaceFolder}/node_modules/@devflow-ai/core/bin/devflow.js init",
        "args": ["--name", "${input:name}", "--type", "${input:type}", "--force", "${input:force}"]
      },
      "when": "workspaceFolder != null"
    },
    {
      "id": "devflow-analyze",
      "name": "分析项目",
      "command": "/devflow-analyze",
      "description": "深度分析项目技术栈、规范和组件",
      "icon": "$(search)",
      "category": "分析",
      "input": {
        "type": "arguments",
        "schema": {
          "type": "object",
          "properties": {
            "deep": {
              "type": "boolean",
              "description": "执行深度分析"
            },
            "output": {
              "type": "string",
              "description": "分析报告输出路径"
            }
          }
        }
      },
      "handler": {
        "type": "cli",
        "command": "node ${workspaceFolder}/node_modules/@devflow-ai/core/bin/devflow.js analyze",
        "args": ["--deep", "${input:deep}", "--output", "${input:output}"]
      },
      "when": "workspaceFolder != null && ${config:devflow.initialized} == true"
    },
    {
      "id": "devflow-run",
      "name": "执行工作流",
      "command": "/devflow-run",
      "description": "执行完整的 8 阶段开发工作流",
      "icon": "$(play)",
      "category": "工作流",
      "input": {
        "type": "arguments",
        "schema": {
          "type": "object",
          "properties": {
            "phase": {
              "type": "string",
              "enum": ["all", "research", "analyze", "design", "split", "dev", "test", "fix", "regression"],
              "description": "执行阶段"
            },
            "parallel": {
              "type": "boolean",
              "description": "启用并行开发"
            },
            "requirement": {
              "type": "string",
              "description": "需求描述或需求文档路径"
            }
          }
        }
      },
      "handler": {
        "type": "cli",
        "command": "node ${workspaceFolder}/node_modules/@devflow-ai/core/bin/devflow.js run",
        "args": ["--phase", "${input:phase}", "--parallel", "${input:parallel}", "--requirement", "${input:requirement}"]
      },
      "when": "workspaceFolder != null && ${config:devflow.initialized} == true"
    },
    {
      "id": "devflow-test",
      "name": "运行测试",
      "command": "/devflow-test",
      "description": "执行单元测试、集成测试或 E2E 测试",
      "icon": "$(beaker)",
      "category": "测试",
      "input": {
        "type": "arguments",
        "schema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["unit", "integration", "e2e", "all"],
              "description": "测试类型"
            },
            "pattern": {
              "type": "string",
              "description": "测试文件匹配模式"
            },
            "watch": {
              "type": "boolean",
              "description": "监听模式"
            }
          }
        }
      },
      "handler": {
        "type": "cli",
        "command": "node ${workspaceFolder}/node_modules/@devflow-ai/core/bin/devflow.js test",
        "args": ["--type", "${input:type}", "--pattern", "${input:pattern}", "--watch", "${input:watch}"]
      },
      "when": "workspaceFolder != null && ${config:devflow.initialized} == true"
    }
  ]
}
